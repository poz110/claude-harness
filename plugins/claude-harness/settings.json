{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/lib/hooks.js && node scripts/lib/hooks.js hook-post-compact"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/workflow.js && node scripts/workflow.js status"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/lib/hooks.js && node scripts/lib/hooks.js hook-session-meta-rules"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/lib/hooks.js && node scripts/lib/hooks.js hook-post-write"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/lib/hooks.js && node scripts/lib/hooks.js hook-post-write"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/lib/hooks.js && node scripts/lib/hooks.js hook-post-bash"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/lib/hooks.js && node scripts/lib/hooks.js hook-post-read"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/lib/hooks.js && node scripts/lib/hooks.js hook-pre-write"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/lib/hooks.js && node scripts/lib/hooks.js hook-pre-bash"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f scripts/lib/hooks.js && node scripts/lib/hooks.js hook-stop"
          }
        ]
      }
    ]
  }
}
