{
  "name": "claude-harness",
  "version": "1.5.7",
  "description": "claude-harness - A state machine driven multi-agent development workflow with 12 specialized agents",
  "main": "scripts/workflow.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "biome check scripts/",
    "format": "biome format --write scripts/",
    "workflow": "node scripts/workflow.js",
    "status": "node scripts/workflow.js status",
    "advance": "node scripts/workflow.js advance",
    "rollback": "node scripts/workflow.js rollback",
    "bump-version": "node scripts/bump-version.js"
  },
  "keywords": [
    "workflow",
    "multi-agent",
    "ai",
    "automation",
    "state-machine",
    "claude",
    "anthropic"
  ],
  "author": "Snow.Li",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^3.0.0",
    "vitest": "^3.0.0",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/poz110/claude-harness"
  }
}
