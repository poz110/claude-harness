{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "_h=scripts/lib/hooks.js; test -f \"$_h\" || _h=$(ls $HOME/.claude/plugins/cache/claude-harness/claude-harness/*/scripts/lib/hooks.js 2>/dev/null|tail -1); test -f \"$_h\" && HARNESS_ROOT=$PWD node \"$_h\" hook-post-compact"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "_w=scripts/workflow.js; test -f \"$_w\" || _w=$(ls $HOME/.claude/plugins/cache/claude-harness/claude-harness/*/scripts/workflow.js 2>/dev/null|tail -1); test -f \"$_w\" && HARNESS_ROOT=$PWD node \"$_w\" status"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "_h=scripts/lib/hooks.js; test -f \"$_h\" || _h=$(ls $HOME/.claude/plugins/cache/claude-harness/claude-harness/*/scripts/lib/hooks.js 2>/dev/null|tail -1); test -f \"$_h\" && HARNESS_ROOT=$PWD node \"$_h\" hook-session-meta-rules"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "_h=scripts/lib/hooks.js; test -f \"$_h\" || _h=$(ls $HOME/.claude/plugins/cache/claude-harness/claude-harness/*/scripts/lib/hooks.js 2>/dev/null|tail -1); test -f \"$_h\" && HARNESS_ROOT=$PWD node \"$_h\" hook-post-write"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "_h=scripts/lib/hooks.js; test -f \"$_h\" || _h=$(ls $HOME/.claude/plugins/cache/claude-harness/claude-harness/*/scripts/lib/hooks.js 2>/dev/null|tail -1); test -f \"$_h\" && HARNESS_ROOT=$PWD node \"$_h\" hook-post-write"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "_h=scripts/lib/hooks.js; test -f \"$_h\" || _h=$(ls $HOME/.claude/plugins/cache/claude-harness/claude-harness/*/scripts/lib/hooks.js 2>/dev/null|tail -1); test -f \"$_h\" && HARNESS_ROOT=$PWD node \"$_h\" hook-post-bash"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "_h=scripts/lib/hooks.js; test -f \"$_h\" || _h=$(ls $HOME/.claude/plugins/cache/claude-harness/claude-harness/*/scripts/lib/hooks.js 2>/dev/null|tail -1); test -f \"$_h\" && HARNESS_ROOT=$PWD node \"$_h\" hook-post-read"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "_h=scripts/lib/hooks.js; test -f \"$_h\" || _h=$(ls $HOME/.claude/plugins/cache/claude-harness/claude-harness/*/scripts/lib/hooks.js 2>/dev/null|tail -1); test -f \"$_h\" && HARNESS_ROOT=$PWD node \"$_h\" hook-pre-write"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "_h=scripts/lib/hooks.js; test -f \"$_h\" || _h=$(ls $HOME/.claude/plugins/cache/claude-harness/claude-harness/*/scripts/lib/hooks.js 2>/dev/null|tail -1); test -f \"$_h\" && HARNESS_ROOT=$PWD node \"$_h\" hook-pre-bash"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "_h=scripts/lib/hooks.js; test -f \"$_h\" || _h=$(ls $HOME/.claude/plugins/cache/claude-harness/claude-harness/*/scripts/lib/hooks.js 2>/dev/null|tail -1); test -f \"$_h\" && HARNESS_ROOT=$PWD node \"$_h\" hook-stop"
          }
        ]
      }
    ]
  }
}
